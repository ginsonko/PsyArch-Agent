{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "HDB Structure Database",
  "type": "object",
  "required": ["structure_db_id", "owner_structure_id", "diff_table", "group_table", "integrity"],
  "properties": {
    "structure_db_id": {"type": "string", "pattern": "^sdb_[0-9]+$"},
    "owner_structure_id": {"type": "string", "pattern": "^st_[0-9]+$"},
    "diff_table": {"type": "array", "items": {"$ref": "diff_entry.schema.json"}},
    "group_table": {"type": "array", "items": {"type": "object"}},
    "integrity": {"type": "object"},
    "created_at": {"type": "integer"},
    "updated_at": {"type": "integer"}
  }
}
