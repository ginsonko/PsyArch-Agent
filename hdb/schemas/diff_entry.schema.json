{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "HDB Diff Entry",
  "type": "object",
  "required": ["entry_id", "entry_type", "content_signature", "base_weight"],
  "properties": {
    "entry_id": {"type": "string"},
    "entry_type": {"type": "string"},
    "target_id": {"type": "string"},
    "content_signature": {"type": "string"},
    "base_weight": {"type": "number"},
    "runtime_er": {"type": "number"},
    "runtime_ev": {"type": "number"},
    "recent_gain": {"type": "number"},
    "fatigue": {"type": "number"},
    "match_count_total": {"type": "integer"},
    "last_updated_at": {"type": "integer"},
    "last_matched_at": {"type": "integer"},
    "path_stats": {"type": "object"},
    "residual_existing_signature": {"type": "string"},
    "residual_incoming_signature": {"type": "string"},
    "ext": {"type": "object"}
  }
}
